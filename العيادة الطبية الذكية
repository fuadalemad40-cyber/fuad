import json
import os

# ضبط إعدادات الصفحة الافتراضية
st.set_page_config(
    page_title="نظام العيادة الذكي لإدارة المواعيد",
    page_icon="🏥",
    layout="wide",
    initial_sidebar_state="expanded"
)

